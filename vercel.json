{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/wp-admin/(.*)", "destination": "/", "permanent": false },
    { "source": "/wp-login.php", "destination": "/", "permanent": false },
    { "source": "/xmlrpc.php", "destination": "/", "permanent": false },

    { "source": "/blog-airbnb-property-management/page/(.*)",
      "destination": "/blog-airbnb-property-management/",
      "permanent": false },

    { "source": "/category/(.*)",
      "destination": "/blog-airbnb-property-management/",
      "permanent": false },

    { "source": "/tag/(.*)",
      "destination": "/blog-airbnb-property-management/",
      "permanent": false },

    { "source": "/author/(.*)",
      "destination": "/",
      "permanent": false },

    { "source": "/contact/",
      "destination": "/contact-airbnb-property-management-torrevieja/",
      "permanent": true },
    { "source": "/contact-us/",
      "destination": "/contact-airbnb-property-management-torrevieja/",
      "permanent": true },

    { "source": "/feed/",
      "destination": "/blog-airbnb-property-management/",
      "permanent": false },
    { "source": "/comments/feed/",
      "destination": "/blog-airbnb-property-management/",
      "permanent": false },
    { "source": "/:slug/feed/",
      "destination": "/:slug/",
      "permanent": false }
  ],
  "headers": [
    {
      "source": "/wp-content/uploads/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(jpg|jpeg|png|gif|webp|svg|woff|woff2|ttf|otf|eot|ico)$",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js)$",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, must-revalidate" }
      ]
    }
  ]
}
